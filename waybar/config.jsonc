{
    "layer": "top",
    "position": "top",
    "height": 26,
    "spacing": 2,

    "modules-left": [
        "hyprland/workspaces",
        "custom/separator",
        "hyprland/window"
    ],
    "modules-center": [],
    "modules-right": [
        "pulseaudio",
        "hyprland/language",
        "network",
        "cpu",
        "temperature",
        "battery",
        "battery#bat2",
        "clock"
    ],

    "include": [
        "~/.config/waybar/modules.json"
    ]
}
